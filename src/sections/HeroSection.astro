---
// HeroSection.astro — Sección principal tipo flyer tecnológico DevOps
---

<section class="hero-section section" id="inicio">
    <div class="container hero-inner">
        <!-- Columna de texto -->
        <div class="hero-content">
            <p class="neon-label">
                <span aria-hidden="true">◈</span>
                Semana del estudiante · UPS 2026
            </p>

            <h1 class="hero-title">
                <span class="hero-title-top">Taller</span>
                <span class="hero-title-accent">de Git y GitHub</span>
                <span class="hero-title-sub glow-blue">
                    Flujos de trabajo y despliegue continuo
                </span>
            </h1>

            <div class="neon-line" aria-hidden="true"></div>

            <p class="hero-description">
                Aprende a trabajar con Git y GitHub mediante ramas, Pull
                Requests, resolución de conflictos y automatización con CI/CD.
                Trabaja en equipo sobre un proyecto real desde el primer día.
            </p>

            <div class="hero-actions">
                <a href="#practica" class="btn-primary">
                    <span aria-hidden="true">→</span> Ver práctica
                </a>
                <a href="#gitflow" class="btn-outline">
                    <span aria-hidden="true">⎇</span> Flujo de ramas
                </a>
            </div>

            <div class="hero-meta">
                <div class="hero-meta-item">
                    <span class="meta-dot green" aria-hidden="true"></span>
                    <span>Martes 9 · junio 2026</span>
                </div>
                <div class="hero-meta-item">
                    <span class="meta-dot blue" aria-hidden="true"></span>
                    <span>11h00 · Aula 1 Juan Bottasso</span>
                </div>
            </div>
        </div>

        <!-- Columna visual -->
        <div class="hero-visual" aria-hidden="true">
            <!-- Símbolo DevOps -->
            <div class="devops-ring">
                <span class="devops-infinity">∞</span>
                <span class="devops-label">DevOps</span>
            </div>

            <!-- Ventana de terminal -->
            <div class="terminal-window">
                <div class="terminal-bar">
                    <span class="t-dot red"></span>
                    <span class="t-dot yellow"></span>
                    <span class="t-dot green"></span>
                    <span class="t-title">git bash</span>
                </div>
                <div class="terminal-body">
                    <p>
                        <span class="t-prompt">$</span>
                        <span class="t-cmd">git checkout</span>
                        <span class="t-branch">-b feature/mi-tarea</span>
                    </p>
                    <p>
                        <span class="t-out"
                            >Switched to a new branch 'feature/mi-tarea'</span
                        >
                    </p>
                    <p>
                        <span class="t-prompt">$</span>
                        <span class="t-cmd">git add</span>
                        <span class="t-arg">.</span>
                    </p>
                    <p>
                        <span class="t-prompt">$</span>
                        <span class="t-cmd">git commit</span>
                        <span class="t-arg">-m "feat: nueva sección"</span>
                    </p>
                    <p>
                        <span class="t-prompt">$</span>
                        <span class="t-cmd">git push</span>
                        <span class="t-arg">origin</span>
                        <span class="t-branch">feature/mi-tarea</span>
                    </p>
                    <p class="t-blink">
                        <span class="t-prompt">$</span>
                        <span class="t-cursor">▌</span>
                    </p>
                </div>
            </div>

            <!-- Logo ASU Software Libre -->
            <div class="asu-badge">
                <img
                    src={`${import.meta.env.BASE_URL}assets/logo.png`}
                    alt="ASU Software Libre"
                    class="asu-logo"
                />
            </div>
            <!-- Tarjeta Git -->
            <div class="hero-badge badge-git">
                <span class="badge-icon">⎇</span>
                <div>
                    <p class="badge-title">Git</p>
                    <p class="badge-desc">Control de versiones</p>
                </div>
            </div>

            <!-- Tarjeta GitHub -->
            <div class="hero-badge badge-github">
                <span class="badge-icon">◎</span>
                <div>
                    <p class="badge-title">GitHub</p>
                    <p class="badge-desc">Pull Requests · CI/CD</p>
                </div>
            </div>

            <!-- Fondo decorativo -->
            <div class="hero-glow-1"></div>
            <div class="hero-glow-2"></div>
        </div>
    </div>
</section>

<style>
    /* ─── Layout ────────────────────── */
    .hero-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding-top: 80px;
        padding-bottom: 80px;
        overflow: hidden;
    }

    .hero-inner {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 64px;
        align-items: center;
    }

    /* ─── Texto ─────────────────────── */
    .hero-content {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .hero-title {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 0;
    }

    .hero-title-top {
        font-size: clamp(3.5rem, 8vw, 6.5rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        line-height: 0.9;
        color: var(--color-text);
        text-shadow: 0 0 40px rgba(255, 255, 255, 0.1);
    }

    .hero-title-accent {
        font-size: clamp(2.4rem, 5.5vw, 4.5rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        line-height: 0.95;
        color: var(--color-accent);
        text-shadow: 0 0 28px rgba(250, 204, 21, 0.55);
    }

    .hero-title-sub {
        font-size: clamp(1rem, 2.5vw, 1.5rem);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        line-height: 1.3;
        margin-top: 8px;
    }

    .hero-description {
        margin-top: 8px;
        font-size: 1.08rem;
        line-height: 1.7;
        color: var(--color-text-soft);
        max-width: 520px;
    }

    .hero-actions {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-top: 36px;
    }

    .hero-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid var(--color-border-soft);
    }

    .hero-meta-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        color: var(--color-muted);
        font-weight: 600;
    }

    .asu-badge {
        /* right: 108px;
         */
        position: absolute;
        bottom: -130px;
        /* right: 150px; */

        width: 305px;
        height: 305px;

        display: grid;
        place-items: center;

        border: 1px solid var(--color-border);
        border-radius: 10px;
        box-shadow: var(--shadow-neon-cyan);
        /* position: absolute; */
        background: rgba(2, 6, 23, 0.92);
    }

    .asu-logo {
        width: 300px;
        height: 300px;
        object-fit: contain;
    }
    .meta-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .meta-dot.green {
        background: #4ade80;
        box-shadow: 0 0 8px rgba(74, 222, 128, 0.6);
    }

    .meta-dot.blue {
        background: var(--color-primary-light);
        box-shadow: 0 0 8px rgba(0, 200, 255, 0.6);
    }

    /* ─── Visual lateral ─────────────── */
    .hero-visual {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        min-height: 480px;
    }

    /* Anillo DevOps */
    .devops-ring {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 2px solid var(--color-border);
        background: radial-gradient(
            circle,
            rgba(0, 102, 255, 0.12),
            transparent 70%
        );
        box-shadow:
            var(--shadow-neon-cyan),
            inset 0 0 24px rgba(0, 200, 255, 0.08);
        position: absolute;
        top: 0;
        right: 0;
    }

    .devops-infinity {
        font-size: 3rem;
        color: var(--color-primary-light);
        text-shadow: 0 0 18px rgba(0, 200, 255, 0.7);
        line-height: 1;
    }

    .devops-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--color-muted);
        margin-top: 2px;
    }

    /* Terminal */
    .terminal-window {
        width: 100%;
        max-width: 420px;
        border: 1px solid rgba(0, 200, 255, 0.28);
        border-radius: 12px;
        background: rgba(2, 6, 23, 0.96);
        box-shadow:
            var(--shadow-neon-cyan),
            0 24px 48px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        margin-top: 48px;
    }

    .terminal-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        background: rgba(15, 23, 42, 0.98);
        border-bottom: 1px solid rgba(0, 200, 255, 0.14);
    }

    .t-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .t-dot.red {
        background: #ff5f57;
    }
    .t-dot.yellow {
        background: #ffbd2e;
    }
    .t-dot.green {
        background: #28ca41;
    }

    .t-title {
        margin-left: 8px;
        font-size: 0.75rem;
        color: var(--color-muted);
        letter-spacing: 0.06em;
    }

    .terminal-body {
        padding: 18px 20px;
        font-family: "Courier New", Courier, monospace;
        font-size: 0.82rem;
        line-height: 2;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .terminal-body p {
        margin: 0;
        white-space: pre;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .t-prompt {
        color: #64748b;
        user-select: none;
    }
    .t-cmd {
        color: #86efac;
    }
    .t-branch {
        color: var(--color-accent);
    }
    .t-arg {
        color: #c4b5fd;
    }
    .t-out {
        color: #64748b;
    }
    .t-cursor {
        animation: blink 1.2s step-end infinite;
    }

    @keyframes blink {
        50% {
            opacity: 0;
        }
    }

    /* Badges flotantes */
    .hero-badge {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border: 1px solid var(--color-border);
        border-radius: 10px;
        background: rgba(2, 6, 23, 0.92);
        box-shadow: var(--shadow-neon-cyan);
        position: absolute;
    }

    .badge-git {
        bottom: -150px;
        left: 10px;
        box-shadow: var(--shadow-neon-purple);
        border-color: rgba(124, 58, 237, 0.45);
    }

    .badge-github {
        bottom: 120px;
        right: 10px;
        box-shadow: var(--shadow-neon-blue);
        border-color: rgba(0, 102, 255, 0.45);
    }

    .badge-icon {
        font-size: 1.4rem;
        color: var(--color-primary-light);
        text-shadow: 0 0 10px rgba(0, 200, 255, 0.6);
    }

    .badge-title {
        font-size: 0.85rem;
        font-weight: 900;
        text-transform: uppercase;
        color: var(--color-text);
        letter-spacing: 0.04em;
        margin: 0;
    }

    .badge-desc {
        font-size: 0.72rem;
        color: var(--color-muted);
        margin: 0;
    }

    /* Glows decorativos */
    .hero-glow-1 {
        position: absolute;
        top: 10%;
        left: 20%;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(0, 102, 255, 0.18),
            transparent 70%
        );
        pointer-events: none;
        filter: blur(24px);
    }

    .hero-glow-2 {
        position: absolute;
        bottom: 15%;
        right: 5%;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(124, 58, 237, 0.2),
            transparent 70%
        );
        pointer-events: none;
        filter: blur(20px);
    }

    /* ─── Responsive ────────────────── */
    @media (max-width: 900px) {
        .hero-inner {
            grid-template-columns: 1fr;
            gap: 48px;
        }

        /* .hero-visual {
            display: none;
        } */
    }

    @media (max-width: 600px) {
        .hero-section {
            padding-top: 40px;
            min-height: auto;
        }

        .hero-actions {
            flex-direction: column;
        }

        .hero-actions a {
            width: 100%;
            justify-content: center;
        }
    }
</style>
